# Groq FREE API key (https://console.groq.com - free signup)
GROQ_API_KEY=your_groq_api_key_here

# OR for fully local (no API needed):
# OLLAMA_BASE_URL=http://localhost:11434

# Vector DB path
CHROMA_DB_PATH=./chroma_db

# PDFs folder
PDF_DIR=./data/pdfs

# Embedding model (free, runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking config
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5



rag-chatbot/
├── requirements.txt
├── .env
├── README.md
├── ingest.py          ← PDF ingestion pipeline
├── embedder.py        ← Embedding generation
├── retriever.py       ← Vector DB + retrieval
├── reranker.py        ← Optional reranking
├── generator.py       ← LLM answer generation
├── app.py             ← Flask/FastAPI web server
├── ui/
│   └── index.html     ← Chat UI
└── data/
    └── pdfs/          ← Place your PDFs here